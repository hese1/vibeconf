{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Glob",
      "Agent",
      "Bash(ruff check*)",
      "Bash(ruff format*)",
      "Bash(uv run ruff*)",
      "Bash(uv run pytest*)",
      "Bash(pytest*)"
    ]
  }
}
